<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F0F0F0">

    <!-- ═══════ 配置区 ═══════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📋 FRP 服务器配置"
        android:textSize="13sp"
        android:textColor="#666"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFF"
        android:padding="4dp"
        android:elevation="1dp">

        <EditText
            android:id="@+id/server_addr"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Server IP"
            android:text="49.232.72.125"
            android:inputType="text"
            android:paddingStart="8dp"
            android:background="@android:color/transparent"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/server_port"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:hint="隧道Port"
            android:inputType="number"
            android:paddingStart="8dp"
            android:background="@android:color/transparent"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/remote_port"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:hint="代理Port"
            android:inputType="number"
            android:paddingStart="8dp"
            android:background="@android:color/transparent"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/auth_token"
            android:layout_width="88dp"
            android:layout_height="44dp"
            android:hint="Token"
            android:inputType="text"
            android:paddingStart="8dp"
            android:background="@android:color/transparent"
            android:textSize="13sp" />
    </LinearLayout>

    <Button
        android:id="@+id/save_btn"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="保存配置"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="10dp" />

    <!-- ═══════ goproxy 区 ═══════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔹 goproxy  (本地代理 :7890)"
        android:textSize="13sp"
        android:textColor="#333"
        android:layout_marginBottom="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFF"
        android:padding="8dp"
        android:elevation="1dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/goproxy_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="○ 未启动"
            android:textSize="13sp"
            android:textColor="#F44336" />

        <Button
            android:id="@+id/goproxy_start"
            android:layout_width="72dp"
            android:layout_height="38dp"
            android:text="启动"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/goproxy_stop"
            android:layout_width="72dp"
            android:layout_height="38dp"
            android:text="停止"
            android:textSize="12sp"
            android:enabled="false" />
    </LinearLayout>

    <!-- ═══════ frpc 区 ═══════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔸 frpc  (隧道 → VPS)"
        android:textSize="13sp"
        android:textColor="#333"
        android:layout_marginBottom="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFF"
        android:padding="8dp"
        android:elevation="1dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/frpc_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="○ 未启动"
            android:textSize="13sp"
            android:textColor="#F44336" />

        <Button
            android:id="@+id/frpc_start"
            android:layout_width="72dp"
            android:layout_height="38dp"
            android:text="启动"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/frpc_stop"
            android:layout_width="72dp"
            android:layout_height="38dp"
            android:text="停止"
            android:textSize="12sp"
            android:enabled="false" />
    </LinearLayout>

    <!-- ═══════ 日志区 ═══════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📜 运行日志"
        android:textSize="13sp"
        android:textColor="#666"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:padding="8dp"
        android:elevation="1dp">

        <TextView
            android:id="@+id/log_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待操作…"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#B0B0B0" />
    </ScrollView>

</LinearLayout>
